# SAATHI environment — copy to .env and edit. Full reference: MASTER_ARCHITECTURE.md §15
# --- network ---
HTTP_PORT=8000                # hub API/UI port
MQTT_HOST=127.0.0.1           # broker (hub-local)
MQTT_PORT=1883
HUB_LAN_IP=192.168.137.1      # printed in startup banner + QR for phone (A3)
# --- paths ---
DB_PATH=data/saathi.db
MODELS_DIR=hub/models
LOG_DIR=logs
# --- pipeline toggles (1=mock) ---
MOCK_NODE=0
MOCK_VISION=0
MOCK_ASR=0
MOCK_LLM=0
MOCK_CLOUD=1                  # default ON until Phase 8 verified on-site
USE_NPU=0                     # flipped per-model in Phase 9
# --- devices ---
CAMERA_INDEX=0
MIC_DEVICE=default
# --- thresholds (calibrated on-site Phase 7) ---
GAS_WARN=0.35
GAS_CRIT=0.60
SOUND_SPIKE=0.55
ESCALATE_SECONDS=30           # DEMO pacing; a real home deployment uses 120 (D-008)
CAMERA_VERIFY_SECONDS=60
ANNOUNCE_REPEAT_SECONDS=15    # voice repeats while an alert is active (D-007); 0 = once
# --- ASR keywords (Phase 5, §11.2): comma-separated substrings matched on the
# lowercased transcript; tune word lists on-site. Model dir lives in MODELS_DIR ---
HELP_KEYWORDS=help,bachao,bachao mujhe,madad
OK_KEYWORDS=i'm fine,im ok,theek hoon,thik hu
ASR_MODEL_FILE=whisper-base-en-onnx   # optimum export DIR: encoder+decoder pair (pinned in download_models.py) + tokenizer JSONs
# --- LLM local ---
LLM_BASE=http://127.0.0.1:8080/v1
LLM_MODEL=llama-3.2-3b-instruct
LLM_TIMEOUT_S=6
# --- Cloud AI 100 (values provided at event; never commit real key) ---
CLOUD_API_BASE=https://PLACEHOLDER.example
CLOUD_API_KEY=PLACEHOLDER
CLOUD_MODEL=PLACEHOLDER
CLOUD_TIMEOUT_S=20
# --- push to phone via ntfy (D-005 hub code, D-006 Option D; OFF unless BOTH
# set). Local tier: run ntfy.exe ON the hub and point at it — lock-screen
# notifications with ZERO internet. Internet tier (https://ntfy.sh) needs the
# event-rules check first. Topic = capability: pick a random private one
# (e.g. saathi-x7k2p9) and set it only in the real .env ---
REMOTE_NOTIFY_URL=            # e.g. http://127.0.0.1:2586 (local) or https://ntfy.sh
REMOTE_NOTIFY_TOPIC=          # subscribe to the same topic in the ntfy phone app
REMOTE_NOTIFY_TIMEOUT_S=5
REMOTE_NOTIFY_REPEAT_S=90     # re-page while unacked (D-008); 0 = single page
REMOTE_NOTIFY_MAX_PAGES=5     # total notifications per alert, first included
# NOTE: notification Click/Acknowledge buttons use HUB_LAN_IP — keep it correct!
